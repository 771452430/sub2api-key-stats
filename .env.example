# Public URL shown in the usage guide. Keep this on the standalone stats domain.
NEXT_PUBLIC_PUBLIC_BASE_URL=https://key.xiaokoudai.cc

# Read-only PostgreSQL connection. Do not use the Sub2API owner credentials here.
DATABASE_URL=postgresql://key_stats_reader:change-me@sub2api-postgres:5432/sub2api
DATABASE_SSL=false

# Internal Sub2API address used by same-domain API proxy routes:
# - /v1/*
# - /responses
# - /responses/*
SUB2API_UPSTREAM_URL=http://sub2api:8080

# Basic in-memory lookup throttling per client IP.
USAGE_LOOKUP_RATE_LIMIT=30
USAGE_LOOKUP_WINDOW_SECONDS=60
